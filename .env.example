# ─────────────────────────────────────────────────────────────────────────────
# V-Watch CCTV AI System — Environment Configuration
# Copy this file to .env and customize for your deployment
# ─────────────────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: Change this to a strong random string (min 32 chars)
SECRET_KEY=change_this_in_production_use_openssl_rand_hex_32

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=vwatch_pass

# ── Camera Configuration ──────────────────────────────────────────────────────
# Options:
#   demo           → synthetic frames, NO camera required (default)
#   0              → /dev/video0 (also uncomment 'devices' in docker-compose.yml)
#   /dev/video0    → explicit device path
#   rtsp://user:pass@192.168.1.100:554/stream1  → RTSP network camera
CAMERA_SOURCE=demo

CAMERA_ID=CAM_001
LOCATION=Main Street Camera
TARGET_FPS=15

# ── Service Ports (change if defaults conflict) ───────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
RELAY_PORT=8002
EDGE_AI_PORT=8001
WATCHDOG_PORT=9090
POSTGRES_PORT=5432

# ── Edge AI ───────────────────────────────────────────────────────────────────
API_KEY=
# YOLO_MODEL_PATH=/app/models/yolov8n.pt   # already set in Dockerfile

# ── Alerts (optional) ─────────────────────────────────────────────────────────
# ENABLE_ALERTS=true
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
