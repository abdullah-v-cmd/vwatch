# V-Watch Backend Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://vwatch:vwatch_pass@localhost:5432/vwatch_db
DATABASE_URL_SYNC=postgresql://vwatch:vwatch_pass@localhost:5432/vwatch_db

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=change_this_to_a_very_long_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# SMS (optional - mock by default)
SMS_PROVIDER=mock
SMS_API_KEY=

# Fine amounts (USD)
DEFAULT_SPEEDING_FINE=200.0
DEFAULT_REDLIGHT_FINE=500.0
DEFAULT_WRONGDIR_FINE=300.0
DEFAULT_LANE_FINE=150.0
